{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flow Downloader",
  "version": "1.0.0",
  "identifier": "com.stanley.flow-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flow Downloader",
        "width": 1300,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https:;",
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Stanley",
    "externalBin": [
      "ytdlp",
      "ffmpeg"
    ],
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      }
    }
  }
}